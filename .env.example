# SSH host alias (from ~/.ssh/config) or full user@host
# Example: pinkman    or    hassio@homeassistant.local
HA_HOST=hassio@homeassistant.local

# Absolute path on HA where the card is rsynced. Must end with a slash.
# After running `npm run push`, files are reachable at /local/dev/ in HA.
HA_DEV_PATH=/config/www/dev/
