# Build artifacts. The bundle (dist/camera-gallery-card.js) is never
# committed — release.yml builds it from the tagged source and attaches
# it to the GitHub Release as an asset. HACS picks it up from there
# (hacs.json: hide_default_branch: true blocks default-branch installs,
# so users always get the asset from a tagged release).
